NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

DB_HOST=localhost
DB_PORT=3306
DB_NAME=clinique_data_base
DB_USER=root
DB_PASSWORD=

DB_POOL_MAX=5
DB_POOL_MIN=1
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

JWT_SECRET=change_me_access_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

UPLOAD_BASE_DIR=uploads
UPLOAD_MAX_SIZE_MB=5
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/webp

MAIL_TOKEN=change_me_mailtrap_token
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=Clinique Dev

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_AUTH=50
RATE_LIMIT_MAX_API=500

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200,http://10.0.2.2:3000

LOG_LEVEL=debug
LOG_DIR=logs
